# ─────────────────────────────────────────────────────────────
# inline — environment configuration
# Copy this file to ".env" and adjust. All values are optional;
# the defaults below let the app run out of the box.
# ─────────────────────────────────────────────────────────────

# Address the server binds to (host:port).
INLINE_BIND=0.0.0.0:8080

# Public base URL of the CUSTOMER app, used to build the link/QR code
# that operators hand to guests. Set this to whatever the customer
# phone will actually reach (your domain, tunnel, or LAN IP).
#   e.g. https://queue.myrestaurant.com   or   http://192.168.1.20:8080
# Leave empty to auto-use the admin's current origin.
INLINE_PUBLIC_URL=

# Operator password. When set, the admin app must send this token to
# add guests / call next / skip, etc. Leave empty to DISABLE auth
# (fine for a quick local demo, NOT for production).
ADMIN_TOKEN=

# Where the queue state is persisted (JSON snapshot). Survives restarts.
INLINE_DATA_FILE=data.json

# Path to the queue definition file (queue types + form fields + brand).
INLINE_CONFIG=config.json
